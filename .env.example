# CMS admin — username + password gate (Phase 5)
# Plaintext credentials. Used at /admin/login. Both fields are
# compared via bcrypt at check time — each attempt costs a hash
# so brute-forcing is slow even if the env surface leaks.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Secret used to sign session JWTs. If unset, falls back to
# ADMIN_PASSWORD (fine for single-user deploys; set explicitly in
# production so you can rotate sessions without rotating the
# password). Generate with e.g. `openssl rand -hex 32`.
AUTH_SECRET=

# Turso (libSQL) — Phase 5
# URL form: libsql://<db-name>-<org>.turso.io
# Or for local dev: file:./local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Cloudflare R2 — Phase 5
# Create a bucket + API token with Object Read & Write.
# R2_PUBLIC_URL is the bucket's public hostname (r2.dev dev URL or
# a custom domain) — used as the href prefix for uploaded assets.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Formspree endpoint for the hero contact drawer. PUBLIC_ prefix
# means Astro inlines it into the client bundle at build time, so
# this is a static config value (the endpoint URL itself isn't a
# secret — Formspree expects it to be in client code). When unset,
# the contact form falls back to opening a mailto: draft. Create a
# form at formspree.io and paste the URL here (and in Vercel env
# vars for production).
PUBLIC_FORMSPREE_ENDPOINT=
