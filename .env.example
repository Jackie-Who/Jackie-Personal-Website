# CMS admin — single password gate (Phase 5)
# The plaintext admin password. Used to sign in at /admin/login.
ADMIN_PASSWORD=

# Secret used to sign session JWTs. If unset, falls back to
# ADMIN_PASSWORD (fine for single-user deploys; set explicitly
# in production to rotate sessions without rotating the password).
AUTH_SECRET=

# Turso (libSQL) — Phase 5
# URL form: libsql://<db-name>.turso.io
# Or for local dev: file:./local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Cloudflare R2 — Phase 5
# Create a bucket + API token with Object Read & Write.
# R2_PUBLIC_URL is the bucket's public hostname (e.g. via custom
# domain or r2.dev) — used as the href prefix for uploaded assets.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
