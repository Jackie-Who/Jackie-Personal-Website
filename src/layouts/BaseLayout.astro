---
import '@/styles/globals.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  bodyClass?: string;
  themeColor?: string;
  /** Optional override for the social-share image. Defaults to the
   *  site-wide /og-image.png (1200×630 dark-navy card with
   *  "Jackie Hu" + "Engineering / Creative"). Provide a per-page
   *  override if you ship a project-specific card. */
  ogImage?: string;
}

const {
  title = 'Jackie Hu',
  description = "Yi Fei (Jackie) Hu — IT Engineer at Amazon, classical flutist, and photographer based in Vancouver, BC, Canada. A personal portfolio split between technology and creativity.",
  pathname = Astro.url.pathname,
  bodyClass = '',
  themeColor = '#fafafa',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(pathname, Astro.site ?? Astro.url);
// Absolute og:image URL — Twitter and LinkedIn require absolute URLs;
// Facebook is more lenient but happy with one. Built relative to the
// canonical base so previews work on preview deploys too.
const ogImageURL = new URL(ogImage, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content="light dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Jackie Hu" />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Jackie Hu — Engineering / Creative portfolio" />
    <!-- Twitter — summary_large_image rendering needs the same URL.
         No twitter:site / twitter:creator since there's no associated
         handle; declaring empty strings is worse than omitting. -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Jackie Hu — Engineering / Creative portfolio" />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font loading — display=swap keeps text visible during load.
         Only the 5 fonts referenced from CSS at base render time are
         loaded eagerly. The 24 fancy display / cursive fonts used
         exclusively by the signature font-cycle on creative hover
         are loaded LAZILY by CenterAnchor.tsx the first time a
         visitor enters the creative side. Saves ~400 KB of font
         requests on first paint for visitors who never hover. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&display=swap"
    />

    <!-- Structured data: Person schema -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Yi Fei (Jackie) Hu',
        alternateName: 'Jackie Hu',
        jobTitle: 'IT Engineer',
        worksFor: { '@type': 'Organization', name: 'Amazon' },
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Vancouver',
          addressRegion: 'BC',
          addressCountry: 'CA',
        },
        url: canonicalURL.toString(),
        sameAs: ['https://github.com/Jackie-Who'],
      })}
    />

    <!-- Client-side router — intercepts navigations so the browser
         never renders a blank/default frame between pages. Combined
         with the swipe overlays on tech/creative, the back button
         plays its outgoing animation and swaps DOM atomically with
         the hero's first paint. No white flash. -->
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-black focus:px-3 focus:py-1 focus:rounded">
      Skip to content
    </a>
    <slot />
  </body>
</html>

<style is:global>
  /* Screen-reader-only utility — Tailwind ships this, but keep as backup */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
