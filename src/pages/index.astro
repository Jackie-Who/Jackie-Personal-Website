---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/hero/HeroSection';
---

<BaseLayout
  title="Jackie Hu"
  description="A personal portfolio split between technology and creativity. Hover left for music and photography, right for engineering and projects."
  themeColor="#fafafa"
  bodyClass="hero-body"
>
  <main id="main" class="hero-main">
    <HeroSection client:only="react" />
    <noscript>
      <div class="hero-noscript">
        <h1>Jackie</h1>
        <p>IT Engineer, Musician, Photographer.</p>
        <p>
          <a href="/tech">Technology portfolio</a>
          &nbsp;·&nbsp;
          <a href="/creative">Creative portfolio</a>
        </p>
      </div>
    </noscript>
  </main>
</BaseLayout>


<style>
  .hero-body,
  .hero-main {
    margin: 0;
    padding: 0;
    overflow: hidden;
    background: var(--neutral-bg);
  }

  .hero-main {
    width: 100vw;
    height: 100vh;
    height: 100svh;
  }

  .hero-noscript {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-align: center;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--neutral-text);
    background: var(--neutral-bg);
  }

  .hero-noscript h1 {
    font-size: 1.75rem;
    font-weight: 500;
    margin: 0;
  }

  .hero-noscript p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--neutral-text-secondary);
  }

  .hero-noscript a {
    color: var(--neutral-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
