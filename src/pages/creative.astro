---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CreativePortfolio from '@/components/creative/CreativePortfolio';
import { loadPhotos, loadTracks } from '@/content/loader';

// Server-render so newly published content appears without a rebuild.
// Loader falls back to the static placeholder arrays when Turso/R2
// aren't configured yet, so this stays functional in Phases 1–4.
export const prerender = false;

const [photos, tracks] = await Promise.all([loadPhotos(), loadTracks()]);
---

<BaseLayout
  title="Jackie Hu"
  description="Classical flutist and photographer. Live performances, solo recordings, and photography galleries."
  themeColor="#0e0a12"
  bodyClass="creative-body"
>
  {/* Pre-hydration theme restore. MUST run before the loader markup
      below renders, otherwise the loader paints in default-dark vars
      for a frame before the body class flips it to light. is:inline
      keeps the script literal in the HTML so it executes synchronously
      as the browser parses past it. */}
  <script is:inline>
    (function () {
      try {
        const saved = window.localStorage.getItem('creative-theme');
        const theme = saved === 'dark' ? 'dark' : 'light';
        document.body.classList.add(theme === 'light' ? 'creative-body-light' : 'creative-body-dark');
      } catch {
        document.body.classList.add('creative-body-light');
      }
    })();
  </script>

  {/* SSR loading screen — rendered as STATIC HTML so it appears the
      moment the browser paints this page's first frame, NOT after
      React hydrates. Without this, the user saw a blank themed
      background during the JS-download / hydrate window, then a
      brief flash of the React loader at the very end (which defeats
      the purpose of having one).

      React (CreativePortfolio) finds this element on mount and adds
      data-hide=true to fade it out. After the fade transition
      completes the element is removed from the DOM entirely, so it
      doesn't interfere with the rest of the page.

      Cat mark uses the same DOM structure as the React CatMark in
      its resting state — the existing cat-mark.css applies. No
      blink / wink without React, but visually identical at the
      moment the loader fades out. */}
  <div class="creative-loading-screen" id="creative-loading-screen" role="status" aria-label="Loading creative portfolio">
    <div class="creative-loading-screen-inner">
      <div class="cat-mark creative-loading-screen-cat">
        <div class="cat-mark-ears" aria-hidden="true">
          <span>^</span>
          <span>^</span>
        </div>
        <div class="cat-mark-face" aria-hidden="true">
          <span class="cat-mark-eye cat-mark-eye-left">•</span>
          <span class="cat-mark-nose">ㅅ</span>
          <span class="cat-mark-eye cat-mark-eye-right">•</span>
        </div>
      </div>
      <span class="creative-loading-screen-signature">Jackie</span>
    </div>
  </div>

  <main id="main">
    <CreativePortfolio photos={photos} tracks={tracks} client:only="react" />
    <noscript>
      <div class="creative-noscript">
        <h1>Jackie</h1>
        <p>Creative portfolio — flute and photography.</p>
        <p><a href="/">← back to hero</a></p>
      </div>
    </noscript>
  </main>
</BaseLayout>

<style is:global>
  .creative-body,
  .creative-body main {
    margin: 0;
    padding: 0;
  }
  /* The body bg is what leaks through on mobile overscroll, so it
     needs to actually track the chosen theme — matching the
     --creative-bg value for each mode below. Without this, dark-mode
     users saw cream flashing through when they bounce-scrolled. */
  .creative-body.creative-body-light,
  .creative-body.creative-body-light main {
    background: #f5eedf;   /* Cream */
  }
  .creative-body.creative-body-dark,
  .creative-body.creative-body-dark main {
    background: #0d0f13;   /* Mist near-black */
  }
</style>

<style>
  .creative-noscript {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: #c8a0b8;
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    text-align: center;
    padding: 24px;
  }

  .creative-noscript h1 {
    margin: 0;
    font-weight: 400;
    font-size: 1.75rem;
  }

  .creative-noscript p {
    margin: 0;
    font-size: 0.95rem;
    color: #9a7898;
  }

  .creative-noscript a {
    color: #d4a0cc;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
